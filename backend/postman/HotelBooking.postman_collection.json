        {
          "name": "Get Booking by ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/bookings/{{bookingId}}"
          }
        },
        {
          "name": "Search Booking",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/bookings/search/69c0c13267deb3b06a2a7d16"
