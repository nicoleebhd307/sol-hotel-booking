            "url": "{{baseUrl}}/api/bookings",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customer\": {\n    \"email\": \"guest@example.com\",\n    \"name\": \"Nguyen Van A\",\n    \"phone\": \"0901234567\",\n    \"identityId\": \"012345678\"\n  },\n  \"roomIds\": [\"{{roomId}}\"],\n  \"check_in\": \"2026-06-01\",\n  \"check_out\": \"2026-06-04\",\n  \"guests\": { \"adults\": 2, \"children\": 0 },\n  \"note\": \"Early check-in requested\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Cancel Booking (Public)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/bookings/{{bookingId}}/cancel",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"guest@example.com\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        }
      ]
    },

