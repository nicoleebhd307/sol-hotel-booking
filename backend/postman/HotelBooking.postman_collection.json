    {
      "name": "Payments",
      "item": [
        {
          "name": "MoMo – Create Payment (QR)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.orderId) pm.collectionVariables.set('momoOrderId', res.orderId);",
                  "if (res.payUrl) console.log('Pay URL:', res.payUrl);",
                  "if (res.qrCodeUrl) console.log('QR Code URL:', res.qrCodeUrl);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/payments/momo/create",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"bookingId\": \"{{bookingId}}\",\n  \"channel\": \"qr\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "channel: 'qr' (MoMo app) or 'card' (ATM/credit card).\nReturns payUrl + qrCodeUrl from MoMo sandbox.\nRequires PAYMENT_GATEWAY_MODE=sandbox in backend .env."
          }
        },
        {
          "name": "MoMo – Create Payment (Card)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/payments/momo/create",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"bookingId\": \"{{bookingId}}\",\n  \"channel\": \"card\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "MoMo – Init V2 Session (Legacy alias)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/payments/momo-v2/init",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"bookingId\": \"{{bookingId}}\",\n  \"channel\": \"qr\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "MoMo – Simulate IPN Callback",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/payments/momo/ipn",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"partnerCode\": \"MOMOBKUN20180529\",\n  \"accessKey\": \"klm05TvNBzhg7h7j\",\n  \"requestId\": \"MOMO_1234567890\",\n  \"amount\": \"1000000\",\n  \"orderId\": \"{{momoOrderId}}\",\n  \"orderInfo\": \"Deposit for booking\",\n  \"orderType\": \"momo_wallet\",\n  \"transId\": \"2345678901\",\n  \"resultCode\": 0,\n  \"message\": \"Successful.\",\n  \"payType\": \"qr\",\n  \"responseTime\": \"1711000000000\",\n  \"extraData\": \"\",\n  \"signature\": \"\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Simulates MoMo calling your IPN endpoint after payment.\nresultCode 0 = success, non-zero = failure.\nSet orderId to the value saved in momoOrderId variable after creating a session."
          }
        },
        {
          "name": "Pay Deposit (Stub/Simulate)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/payments/deposit",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"bookingId\": \"{{bookingId}}\",\n  \"paymentMethod\": \"momo\",\n  \"simulateStatus\": \"success\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "simulateStatus: 'success' or 'failed'"
          }
        }
      ]
    },

