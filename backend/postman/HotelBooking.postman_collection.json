            "body": {
              "mode": "raw",
              "raw": "{ \"username\": \"admin\", \"password\": \"wrongpassword\" }"
            }
          },
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('401 invalid credentials', () => pm.response.to.have.status(401));"
            ]}
          }]
        },
        {
          "name": "POST /api/admin/login  – 400 missing fields",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/admin/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{}" }
          },
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('400 missing fields', () => pm.response.to.have.status(400));"
            ]}
          }]
        }
      ]
    },

    {
      "name": "7 – Admin: Manage Bookings",
      "item": [
        {
          "name": "GET /api/admin/bookings  – list all",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/admin/bookings",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }]
          },
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('200 list', () => {",
              "  pm.response.to.have.status(200);",
              "  pm.expect(pm.response.json().items).to.be.an('array');",
              "});"
            ]}
          }]
        },
        {
          "name": "GET /api/admin/bookings?status=pending",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/admin/bookings?status=pending",
              "query": [{ "key": "status", "value": "pending" }]
            },
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }]
          },
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('200 filtered by pending', () => pm.response.to.have.status(200));"
            ]}
          }]
        },
        {
          "name": "GET /api/admin/bookings?status=confirmed&limit=5",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/admin/bookings?status=confirmed&limit=5",
              "query": [
                { "key": "status", "value": "confirmed" },
                { "key": "limit",  "value": "5" }
              ]
            },
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }]
          },
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('200 confirmed list', () => pm.response.to.have.status(200));"
            ]}
          }]
        },
        {
          "name": "GET /api/admin/bookings/:id  – detail",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/admin/bookings/{{bookingId}}",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }]
          },
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('200 detail', () => {",
              "  pm.response.to.have.status(200);",
              "  pm.expect(pm.response.json().booking).to.have.property('_id');",
              "});"
            ]}
          }]
        },
        {
          "name": "POST /api/admin/bookings  – create manual booking (confirmImmediately)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/admin/bookings",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customer\": {\n    \"name\": \"Walk-in Guest\",\n    \"email\": \"walkin@hotel.local\",\n    \"phone\": \"0909999888\"\n  },\n  \"roomIds\": [\"{{roomId}}\"],\n  \"check_in\": \"2026-06-01\",\n  \"check_out\": \"2026-06-03\",\n  \"guests\": { \"adults\": 2, \"children\": 1 },\n  \"note\": \"Walk-in offline booking\",\n  \"confirmImmediately\": true\n}"
            }
          },
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('201 manual booking confirmed', () => {",
              "  pm.response.to.have.status(201);",
              "  pm.expect(pm.response.json().status).to.eql('confirmed');",
              "});"
            ]}
          }]
        },
        {
          "name": "POST /api/admin/bookings/:id/check-in",
