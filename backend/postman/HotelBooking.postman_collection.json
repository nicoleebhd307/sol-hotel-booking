{
  "info": {
    "name": "Hotel Booking API – Full Suite",
    "_postman_id": "hotel-booking-api-v2",
    "description": "Complete test suite for all backend API endpoints.\n\nSetup:\n1. Set collection variable `baseUrl` to your backend URL.\n2. Run requests in order — scripts auto-save tokens and IDs between requests.\n3. Login first (Auth or Admin Login folder) to populate `adminToken` before calling protected endpoints.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl",           "value": "http://localhost:5000" },
    { "key": "adminToken",        "value": "" },
    { "key": "receptionistToken", "value": "" },
    { "key": "bookingId",         "value": "" },
    { "key": "roomId",            "value": "" },
    { "key": "roomTypeId",        "value": "" },
    { "key": "customerId",        "value": "" },
    { "key": "refundId",          "value": "" },
    { "key": "momoOrderId",       "value": "" }
  ],
  "item": [

    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/health"
          }
        }
      ]
    },

    {
      "name": "Auth",
      "item": [
        {
          "name": "Login (Staff)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "const token = res.token || (res.data && res.data.token);",
                  "pm.test('Login should return token', function () { pm.expect(token).to.be.a('string').and.not.empty; });",
                  "if (token) {",
                  "  pm.collectionVariables.set('receptionistToken', token);",
                  "  pm.collectionVariables.set('adminToken', token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"reception1@hotel.com\",\n  \"password\": \"123456\"\n}"
            }
          }
        },
        {
          "name": "Get My Profile",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/auth/profile",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }]
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/auth/logout",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }]
          }
        }
      ]
    },

    {
      "name": "Admin Login",
      "item": [
        {
          "name": "Admin Portal Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "const token = res.token || (res.data && res.data.token);",
                  "pm.test('Admin login should return token', function () { pm.expect(token).to.be.a('string').and.not.empty; });",
                  "if (token) pm.collectionVariables.set('adminToken', token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/admin/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"manager@hotel.com\",\n  \"password\": \"123456\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Uses 'email' field. Saves token to adminToken variable."
          }
        }
      ]
    },

    {
      "name": "Rooms",
      "item": [
        {
          "name": "Get All Rooms",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "const rooms = Array.isArray(res) ? res : (res.rooms || res.data || []);",
                  "if (rooms.length > 0) pm.collectionVariables.set('roomId', rooms[0]._id);"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/rooms"
          }
        },
        {
          "name": "Get Room by ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/rooms/{{roomId}}"
          }
        },
        {
          "name": "Get All Room Types",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "const types = Array.isArray(res) ? res : (res.roomTypes || res.data || []);",
                  "if (types.length > 0) pm.collectionVariables.set('roomTypeId', types[0]._id);"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/rooms/types"
          }
        },
        {
          "name": "Get Room Type by ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/rooms/types/{{roomTypeId}}"
          }
        },
        {
          "name": "Get Available Rooms",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/rooms/available?check_in=2026-06-01&check_out=2026-06-05",
              "query": [
                { "key": "check_in",  "value": "2026-06-01" },
                { "key": "check_out", "value": "2026-06-05" }
              ]
            }
          }
        },
        {
          "name": "Update Room (Admin)",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/api/rooms/{{roomId}}",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"available\"\n}"
            }
          }
        }
      ]
    },

    {
      "name": "Bookings (Public)",
